<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <!--水波纹颜色-->
        <item name="colorControlHighlight">#1f000000</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>


    <style name="AppThemeScarlet" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimaryScarlet</item>
        <item name="colorPrimaryDark">@color/colorPrimaryScarletDark</item>

        <item name="colorAccent">@color/colorAccent</item>

        <!--水波纹颜色-->
        <item name="colorControlHighlight">#1f000000</item>

    </style>

    <style name="ViewTheme">
        <!--水波纹颜色-->
        <item name="colorControlHighlight">@color/md_green_200_color_code</item>
    </style>
    <style name="textStyle1">
        <!--水波纹颜色-->
        <item name="android:textColor">#ff4081</item>
    </style>

    <style name="backStyleRed100">
        <!--水波纹颜色-->
        <item name="android:background">@color/md_green_100_color_code</item>
    </style>

    <style name="backStyleRed800">
        <!--水波纹颜色-->
        <item name="android:background">@color/md_green_800_color_code</item>
    </style>
    <style name="backStyleRed">
        <item name="android:background">@color/red_back</item>
    </style>

    <style name="backStyleRed_dark">
        <item name="android:background">@color/_d12324_520d0d</item>
    </style>



    <style name="text_yellow_style">
        <item name="android:textColor">@color/text_yellow</item>
    </style>

    <style name="text_left_icon">
        <item name="android:drawableLeft">@mipmap/ic_star</item>
    </style>

    <style name="TextViewYellowAppearance" parent="android:style/TextAppearance.Material">        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_yellow</item>
    </style>

    <!-- 底部弹窗动画 -->
    <style name="BottomSheetAnimation" parent="android:Animation">
        <item name="android:windowEnterAnimation">@anim/popup_enter</item>
        <item name="android:windowExitAnimation">@anim/popup_exit</item>
    </style>
    <!-- 底部弹窗 Dialog 样式 -->
    <style name="BottomSheetDialogStyle" parent="android:style/Theme.Dialog">
        <!-- 边框 -->
        <item name="android:windowFrame">@null</item>
        <!-- 是否浮现在 activity 之上 -->
        <item name="android:windowIsFloating">true</item>
        <!-- 半透明 -->
        <item name="android:windowIsTranslucent">true</item>
        <!-- 无标题 -->
        <item name="android:windowNoTitle">true</item>
        <!-- 背景透明 -->
        <item name="android:background">@android:color/transparent</item>
        <!-- 弹窗背景透明 -->
        <item name="android:windowBackground">@android:color/transparent</item>
        <!-- 遮罩层透明 -->
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.5</item>
    </style>



</resources>
