<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color"
    android:orientation="vertical"
    tools:context=".ImageViewSimpleActivity">

    <com.aliya.uimode.sample.view.TopBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@mipmap/ic_star_pressed" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:src="@mipmap/ic_star_pressed"
                app:tint="@color/_ff4081_aa8080" />

            <com.noober.background.view.BLTextView
                android:layout_width="50dp"
                android:layout_height="24dp"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="账号"
                android:textColor="@color/text_dark_primary"
                android:textSize="14sp"
                app:bl_corners_radius="10dp"
                app:bl_stroke_color="@color/_ff4081_aa8080"
                app:bl_stroke_width="2dp" />

            <com.noober.background.view.BLTextView
                android:layout_width="50dp"
                android:layout_height="24dp"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="账号"
                android:textColor="@color/text_dark_primary"
                android:textSize="14sp"
                app:bl_corners_radius="10dp"
                app:bl_solid_color="@color/_ff4081_aa8080" />


            <com.noober.background.view.BLTextView
                android:layout_width="100dp"
                android:layout_height="24dp"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="账号"
                android:textColor="@color/text_dark_primary"
                android:textSize="14sp"
                app:bl_corners_radius="10dp"
                app:bl_gradient_angle="0"
                app:bl_gradient_endColor="@color/_fdc247_7e6023"
                app:bl_gradient_startColor="@color/_ff4081_aa8080" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/community_ic_draft_box"
                app:tint="@color/text_dark_primary" />


            <com.noober.background.view.BLTextView
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:padding="10dp"
                android:text="账号"
                android:textColor="@color/text_dark_primary"
                android:textSize="14sp"
                app:bl_corners_radius="10dp"
                app:bl_stroke_color="@color/text_dark_primary"
                app:bl_stroke_width="1dp" />

            <com.noober.background.view.BLView
                android:layout_width="50dp"
                android:layout_height="20dp"
                android:layout_marginTop="10dp"
                android:gravity="center"
                app:bl_corners_radius="10dp"
                app:bl_solid_color="@color/text_dark_primary"
                app:uiMode_ignore="" />

            <com.noober.background.view.BLView
                android:layout_width="50dp"
                android:layout_height="20dp"
                android:layout_marginTop="10dp"
                android:gravity="center"
                app:bl_corners_radius="10dp"
                app:bl_solid_color="@color/text_dark_primary" />


            <View
                android:id="@+id/view_background_tint_test"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="25dp"
                android:background="@mipmap/ic_home"
                android:tag="view_background_tint_test"
                app:backgroundTint="@color/text_dark_primary" />

        </LinearLayout>


    </ScrollView>
</LinearLayout>

